# Environment Variables WarungDigital
# Copy file ini ke .env dan isi nilainya

# NODE
NODE_ENV=development
PORT=3000

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=warung_digital
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_this_to_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# WhatsApp - CallMeBot (Tier 1)
CALLMEBOT_KEY=your_callmebot_key

# WhatsApp - WAHA (Tier 2)
WAHA_URL=http://localhost:3001
WAHA_API_KEY=your_waha_key

# n8n
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# Google Maps
GOOGLE_MAPS_API_KEY=your_maps_key

# Google Sheets ID (Tier 1)
SPREADSHEET_ID=your_google_sheets_id

# Cloud Storage (Backup)
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_BUCKET=warung-digital-backups
S3_ACCESS_KEY=your_key
S3_SECRET_KEY=your_secret

# App
APP_NAME=WarungDigital
APP_URL=http://localhost:5173
